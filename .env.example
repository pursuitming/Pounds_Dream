# ===================================================
# Pounds-Dream Docker 生产环境配置
# ===================================================
# 使用方法：
#   1. cp .env.example .env
#   2. 修改 .env 中的值
#   3. docker-compose up -d --build
# ===================================================

# ---- 数据库配置 ----
# 重要：生产环境请使用强密码！
DB_PASSWORD=your_strong_password_here

# ---- JWT 配置 ----
# 重要：生产环境请修改为随机字符串（至少 32 位）！
# 可以使用命令生成：openssl rand -base64 32
JWT_SECRET=your_random_jwt_secret_at_least_32_chars

# ---- AI 接口配置（可选）----
# 如需 AI 功能，填写以下配置
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
